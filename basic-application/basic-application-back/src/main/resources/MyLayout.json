{
  "instant": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSS'Z'",
      "timeZone": "UTC"
    }
  },
  "thread": {
    "$resolver": "thread",
    "field": "name"
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "loggerName": {
    "$resolver": "logger",
    "field": "name"
  },
  "userId": {
    "$resolver": "mdc",
    "key": "user-id"
  },
  "hostName": {
    "$resolver": "mdc",
    "key": "host-name"
  },
  "url": {
    "$resolver": "mdc",
    "key": "ow-url"
  },
  "methodeSignature": {
    "$resolver": "mdc",
    "key": "methode-signature"
  },
  "executionTime": {
    "$resolver": "mdc",
    "key": "execution-time"
  },
  "message": {
    "$resolver": "message",
    "stringified": true
  },
  "thrown": {
    "message": {
      "$resolver": "exception",
      "field": "message"
    },
    "name": {
      "$resolver": "exception",
      "field": "className"
    },
    "extendedStackTrace": {
      "$resolver": "exception",
      "field": "stackTrace",
      "stackTrace": {
        "stringified": true
      }
    }
  }
}